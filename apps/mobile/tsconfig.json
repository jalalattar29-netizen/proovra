{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "Bundler",
    "paths": {
      "@proovra/ui": [
        "../../packages/ui/src/index.ts"
      ]
    },
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "App.tsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
