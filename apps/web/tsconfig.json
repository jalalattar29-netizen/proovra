{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "module": "esnext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "jsx": "preserve",
    "incremental": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@proovra/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@proovra/shared": [
        "../../packages/shared/src/index.ts"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",

    "components/**/*.ts",
    "components/**/*.tsx",

    "lib/**/*.ts",
    "lib/**/*.tsx",

    "next-env.d.ts",
    "types/**/*.ts",
    ".next/types/**/*.ts"
  ],
    "exclude": [
    "node_modules"
  ]
}
