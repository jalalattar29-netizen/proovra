DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>?sslmode=require
REDIS_URL=redis://<host>:6379

S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=proovra-prod-assets
# Optional: set to CDN/base URL if used
S3_PUBLIC_BASE_URL=
# Set true for local MinIO over http
S3_ALLOW_INSECURE=false

WORKER_BUILD_INFO=local
WORKER_PORT=8090
LOG_LEVEL=info
