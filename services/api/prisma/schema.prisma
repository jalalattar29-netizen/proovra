model DemoRequest {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName         String              @map("full_name") @db.VarChar(160)
  workEmail        String              @map("work_email") @db.VarChar(320)
  organization     String?             @db.VarChar(180)
  jobTitle         String?             @map("job_title") @db.VarChar(120)
  country          String?             @db.VarChar(120)
  teamSize         String?             @map("team_size") @db.VarChar(64)
  useCase          String              @map("use_case")
  message          String?

  source           String?             @db.VarChar(120)
  sourcePath       String?             @map("source_path") @db.VarChar(512)
  referrer         String?             @db.VarChar(2048)
  utmSource        String?             @map("utm_source") @db.VarChar(160)
