# Neon (Frankfurt) - use sslmode=require
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>?sslmode=require
DIRECT_URL=postgresql://<user>:<password>@<host>:5432/<db>?sslmode=require

# Storage (Cloudflare R2 - S3 compatible)
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=proovra-prod-assets
# Optional: set to CDN/base URL if used
S3_PUBLIC_BASE_URL=
# Set true for local MinIO over http
S3_ALLOW_INSECURE=false

# Redis (BullMQ)
REDIS_URL=redis://<host>:6379

# Auth
AUTH_JWT_SECRET=change-me
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=https://www.proovra.com/auth/apple/callback
WEB_BASE_URL=https://www.proovra.com
APP_BASE_URL=https://app.proovra.com

# Signing
SIGNING_KEY_ID=proovra_ed25519
SIGNING_KEY_VERSION=1
SIGNING_PRIVATE_KEY_PATH=keys/signing-private.pem
SIGNING_PUBLIC_KEY_PATH=keys/signing-public.pem

# CORS
CORS_ORIGINS=https://www.proovra.com,https://proovra.com,https://app.proovra.com

# Public verify rate limit
VERIFY_RATE_LIMIT_MAX=60
VERIFY_RATE_LIMIT_WINDOW_SEC=60

# Plan limits
FREE_EVIDENCE_LIMIT=3

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAYG_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_PAYG_PRICE_CENTS=200
STRIPE_PRO_PRICE_CENTS=1500
STRIPE_TEAM_PRICE_CENTS=4000

# PayPal (sandbox)
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
